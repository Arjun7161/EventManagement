@model IEnumerable<EventManagementMVC.Models.Event>

<h2>All Events</h2>

<div class="container">
    <div class="row">
        @foreach (var ev in Model)
        {
            <div class="col-md-4">
                <div class="event-card">
                    <h4>@ev.Title</h4>
                    <p>@ev.Description</p>
                    <p><strong>Date:</strong> @ev.Date.ToShortDateString()</p>
                    <p><strong>Time:</strong> @ev.Time.ToShortTimeString()</p>
                    <p><strong>Location:</strong> @ev.Location</p>
                    <div class="d-flex justify-content-between mt-2">
                        <a asp-action="Edit" asp-route-id="@ev.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@ev.Id" class="btn btn-danger btn-sm">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Create" class="btn btn-primary">Add New Event</a>
    </div>
</div>